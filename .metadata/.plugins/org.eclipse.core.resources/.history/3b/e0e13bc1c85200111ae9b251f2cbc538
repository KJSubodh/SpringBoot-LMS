package com.pentagon.LibraryManagementSystem.DAO;

import java.util.List;
import java.util.Optional;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Repository;

import com.pentagon.LibraryManagementSystem.Entity.User;
import com.pentagon.LibraryManagementSystem.Entity.Profile;
import com.pentagon.LibraryManagementSystem.Repository.UserRepository;
import com.pentagon.LibraryManagementSystem.Repository.ProfileRepository;

@Repository
public class UserDAO {

    @Autowired
    private UserRepository userRepository;
    
    @Autowired
    private ProfileRepository profileRepository;  // ✅ Add this

    // ✅ MODIFIED: Save user with auto-profile creation
    public User saveUser(User u) {
        // If user has profile, ensure it's properly linked
        if (u.getProfile() != null) {
            u.getProfile().setUser(u);
        }
        return userRepository.save(u);
    }
    
    // ✅ NEW: Create user with profile
    public User createUserWithProfile(User user, Profile profile) {
        profile.setUser(user);
        user.setProfile(profile);
        return userRepository.save(user);
    }

    public List<User> getAllUsers() {
        return userRepository.findAll();
    }

    public User getUserById(int id) {
        Optional<User> userOpt = userRepository.findById(id);
        if (userOpt.isPresent()) {
            return userOpt.get();
        } else {
            return null;
        }
    }

    // ✅ NEW: Update user
    public User updateUser(int id, User updatedUser) {
        Optional<User> userOpt = userRepository.findById(id);
        if (userOpt.isPresent()) {
            User existingUser = userOpt.get();
            existingUser.setName(updatedUser.getName());
            
            // Update profile if present
            if (updatedUser.getProfile() != null) {
                Profile profile = existingUser.getProfile();
                if (profile == null) {
                    profile = new Profile();
                }
                profile.setEmail(updatedUser.getProfile().getEmail());
                profile.setPhone(updatedUser.getProfile().getPhone());
                profile.setUser(existingUser);
                existingUser.setProfile(profile);
            }
            
            return userRepository.save(existingUser);
        }
        return null;
    }

    public String deleteUser(int id) {
        Optional<User> userOpt = userRepository.findById(id);
        if (userOpt.isPresent()) {
            userRepository.delete(userOpt.get());
            return "User and associated profile deleted successfully";
        } else {
            return "User not found";
        }
    }

    public List<User> getByName(String name) {
        return userRepository.findByName(name);
    }
}