package com.pentagon.LibraryManagementSystem.DAO;

import java.util.List;
import java.util.Optional;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Repository;

import com.pentagon.LibraryManagementSystem.Entity.Category;
import com.pentagon.LibraryManagementSystem.Repository.CategoryRepository;

@Repository
public class CategoryDAO {

    @Autowired
    private CategoryRepository category;

    // Requirement: Add new category [cite: 49, 88]
    public Category addCategory(Category c) {
        return category.save(c);
    }

    // Requirement: Fetch all categories [cite: 50, 89]
    public List<Category> getAllCategories() {
        return category.findAll();
    }

    // Helper method to fetch a single category by ID
    public Category getById(int id) {
        Optional<Category> categoryOpt = category.findById(id);
        if (categoryOpt.isPresent()) {
            return categoryOpt.get();
        } else {
            return null;
        }
    }
}