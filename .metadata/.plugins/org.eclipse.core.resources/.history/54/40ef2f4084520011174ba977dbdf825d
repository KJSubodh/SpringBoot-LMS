package com.pentagon.LibraryManagementSystem.DAO;

import java.util.List;
import java.util.Optional;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Repository;

import com.pentagon.LibraryManagementSystem.Entity.Book;
import com.pentagon.LibraryManagementSystem.Entity.User;
import com.pentagon.LibraryManagementSystem.Repository.BookRepository;
import com.pentagon.LibraryManagementSystem.Repository.UserRepository;

@Repository
public class BookDAO {
	@Autowired
	private BookRepository book;

	@Autowired
	private UserRepository user;

	public Book addBook(Book b) {
		return book.save(b);
	}

	public List<Book> getAllBooks() {
		return book.findAll();
	}

	public Book borrow(int b_id, int u_id) {
		Optional<Book> bookOpt = book.findById(b_id);
		Optional<User> userOpt = user.findById(u_id);

		if (bookOpt.isEmpty() || userOpt.isEmpty()) {
			return null;
		}

		Book b = bookOpt.get();

		if (b.getUser() != null) {
			return null;
		}

		User u = userOpt.get();

		b.setUser(u);

		return book.save(b);
	}
	
	public Book returnBook(int id) {
		Optional<Book> book0 = book.findById(id);
		if (book0.isPresent()) {
			Book b = book0.get();
			b.setUser(null);
			return book.save(b);
		} else {
			return null;
		}
	}
	
	public Book getById(int id) {
		Optional <Book> o = book.findById(id);
		if(o.isPresent())
		{
			return o.get();
		}
	}

}
