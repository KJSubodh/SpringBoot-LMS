package com.pentagon.LibraryManagementSystem.DAO;

import java.util.List;
import java.util.Optional;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Repository;

import com.pentagon.LibraryManagementSystem.Entity.Author;
import com.pentagon.LibraryManagementSystem.Repository.AuthorRepository;

@Repository
public class AuthorDAO {

    @Autowired
    private AuthorRepository authorRepository;

    // Requirement: Add new author 
    public Author addAuthor(Author a) {
        return authorRepository.save(a);
    }

    // Requirement: Fetch all authors [cite: 46, 79]
    public List<Author> getAllAuthors() {
        return authorRepository.findAll();
    }

    // Requirement: Fetch author's books 
    // This method retrieves the Author object; if your Author entity has 
    // a One-to-Many mapping, you can access the books from the returned object.
    public Author getAuthorById(int id) {
        Optional<Author> authorOpt = authorRepository.findById(id);
        if (authorOpt.isPresent()) {
            return authorOpt.get();
        } else {
            return null;
        }
    }
}