package com.pentagon.LibraryManagementSystem.Controller;

import com.pentagon.LibraryManagementSystem.DAO.BookDAO;
import com.pentagon.LibraryManagementSystem.Entity.Book;
import com.pentagon.LibraryManagementSystem.Entity.Category;
import com.pentagon.LibraryManagementSystem.DTO.ResponseStructure;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import org.springframework.http.ResponseEntity;
import org.springframework.http.HttpStatus;

import java.util.List;

@RestController
@RequestMapping("/books")
public class BookController {

    @Autowired
    private BookDAO bookDAO;

    @PostMapping
    public ResponseEntity<ResponseStructure<Book>> addBook(@RequestBody Book b) {
        try {
            Book savedBook = bookDAO.addBook(b);
            ResponseStructure<Book> response = ResponseStructure.created(savedBook);
            return ResponseEntity.status(HttpStatus.CREATED).body(response);
        } catch (Exception e) {
            ResponseStructure<Book> response = ResponseStructure.error(
                HttpStatus.INTERNAL_SERVER_ERROR.value(),
                "Error creating book: " + e.getMessage()
            );
            return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(response);
        }
    }

    @GetMapping
    public ResponseEntity<ResponseStructure<List<Book>>> getAllBooks() {
        List<Book> books = bookDAO.getAllBooks();
        ResponseStructure<List<Book>> response = ResponseStructure.success(books);
        return ResponseEntity.ok(response);
    }

    @GetMapping("/{id}")
    public ResponseEntity<ResponseStructure<Book>> getBookById(@PathVariable int id) {
        Book book = bookDAO.getBookById(id);
        if (book != null) {
            ResponseStructure<Book> response = ResponseStructure.success(book);
            return ResponseEntity.ok(response);
        } else {
            ResponseStructure<Book> response = ResponseStructure.notFound("Book not found with ID: " + id);
            return ResponseEntity.status(HttpStatus.NOT_FOUND).body(response);
        }
    }

    @PutMapping("/{id}/borrow/{userId}")
    public ResponseEntity<ResponseStructure<Book>> borrowBook(@PathVariable int id, @PathVariable int userId) {
        try {
            Book borrowedBook = bookDAO.borrow(id, userId);
            if (borrowedBook != null) {
                ResponseStructure<Book> response = ResponseStructure.success("Book borrowed successfully", borrowedBook);
                return ResponseEntity.ok(response);
            } else {
                ResponseStructure<Book> response = ResponseStructure.badRequest("Book is already borrowed or user not found");
                return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(response);
            }
        } catch (IllegalStateException e) {
            ResponseStructure<Book> response = ResponseStructure.badRequest(e.getMessage());
            return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(response);
        } catch (Exception e) {
            ResponseStructure<Book> response = ResponseStructure.error(
                HttpStatus.INTERNAL_SERVER_ERROR.value(),
                "Error borrowing book: " + e.getMessage()
            );
            return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(response);
        }
    }
    
    @PutMapping("/{id}/return")
    public ResponseEntity<ResponseStructure<Book>> returnBook(@PathVariable int id) {
        try {
            Book returnedBook = bookDAO.returnBook(id);
            if (returnedBook != null) {
                ResponseStructure<Book> response = ResponseStructure.success("Book returned successfully", returnedBook);
                return ResponseEntity.ok(response);
            } else {
                ResponseStructure<Book> response = ResponseStructure.notFound("Book not found with ID: " + id);
                return ResponseEntity.status(HttpStatus.NOT_FOUND).body(response);
            }
        } catch (Exception e) {
            ResponseStructure<Book> response = ResponseStructure.error(
                HttpStatus.INTERNAL_SERVER_ERROR.value(),
                "Error returning book: " + e.getMessage()
            );
            return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(response);
        }
    }
    
    @PutMapping("/{id}")
    public ResponseEntity<ResponseStructure<Book>> updateBook(@PathVariable int id, @RequestBody Book b) {
        try {
            Book updatedBook = bookDAO.updateBook(id, b);
            if (updatedBook != null) {
                ResponseStructure<Book> response = ResponseStructure.success("Book updated successfully", updatedBook);
                return ResponseEntity.ok(response);
            } else {
                ResponseStructure<Book> response = ResponseStructure.notFound("Book not found with ID: " + id);
                return ResponseEntity.status(HttpStatus.NOT_FOUND).body(response);
            }
        } catch (Exception e) {
            ResponseStructure<Book> response = ResponseStructure.error(
                HttpStatus.INTERNAL_SERVER_ERROR.value(),
                "Error updating book: " + e.getMessage()
            );
            return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(response);
        }
    }
    
    @PutMapping("/{id}/categories")
    public ResponseEntity<ResponseStructure<Book>> updateCategories(@PathVariable int id, @RequestBody List<Category> categories) {
        try {
            Book updatedBook = bookDAO.updateBookCategories(id, categories);
            if (updatedBook != null) {
                ResponseStructure<Book> response = ResponseStructure.success("Categories updated successfully", updatedBook);
                return ResponseEntity.ok(response);
            } else {
                ResponseStructure<Book> response = ResponseStructure.notFound("Book not found with ID: " + id);
                return ResponseEntity.status(HttpStatus.NOT_FOUND).body(response);
            }
        } catch (Exception e) {
            ResponseStructure<Book> response = ResponseStructure.error(
                HttpStatus.INTERNAL_SERVER_ERROR.value(),
                "Error updating categories: " + e.getMessage()
            );
            return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(response);
        }
    }
}