package com.pentagon.LibraryManagementSystem.Controller;

import com.pentagon.LibraryManagementSystem.DAO.AuthorDAO;
import com.pentagon.LibraryManagementSystem.Entity.Author;
import com.pentagon.LibraryManagementSystem.Entity.Book;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import org.springframework.http.ResponseEntity;

import java.util.List;

@RestController
@RequestMapping("/authors")
public class AuthorController {

    @Autowired
    private AuthorDAO authorDAO;

    @PostMapping
    public Author addAuthor(@RequestBody Author a) {
        return authorDAO.addAuthor(a);
    }

    @GetMapping
    public List<Author> getAllAuthors() {
        return authorDAO.getAllAuthors();
    }
    
    @GetMapping("/{id}")
    public ResponseEntity<Author> getAuthorById(@PathVariable int id) {
        Author author = authorDAO.getAuthorById(id);
        if (author != null) {
            return ResponseEntity.ok(author);
        } else {
            return ResponseEntity.notFound().build();
        }
    }
    
    // ✅ NEW: Get all books by an author
    @GetMapping("/{id}/books")
    public ResponseEntity<List<Book>> getAuthorBooks(@PathVariable int id) {
        Author author = authorDAO.getAuthorById(id);
        if (author != null && author.getBook() != null) {
            return ResponseEntity.ok(author.getBook());
        } else {
            return ResponseEntity.notFound().build();
        }
    }
}